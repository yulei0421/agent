{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "jsx": "react-jsx",
    "allowJs": false,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["server/**/*.ts", "tests/**/*.ts"]
}
