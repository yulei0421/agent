{
  "name": "deepseek-agent-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx watch server/index.ts\" \"vite --host 127.0.0.1\"",
    "server": "tsx server/index.ts",
    "client": "vite --host 127.0.0.1",
    "build": "vite build",
    "test": "tsx --test tests/*.test.ts",
    "test:ts": "tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/langgraph": "^1.4.8",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/platform-ws": "^11.1.28",
    "@nestjs/websockets": "^11.1.28",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "vite": "^7.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
